<template>
	<view class="user-center-container">
		<view class="profile-header">
			<view class="user-avatar" :style="{ background: getAvatarGradient() }">
				<text class="avatar-emoji"></text>
			</view>
			<view class="user-info">
				<text class="user-name">{{ userInfo.nickname || '未登录' }}</text>
				<text class="user-bio">{{ userInfo.bio || '这个人很懒，什么都没写' }}</text>
				<view class="user-badges">
					<view class="badge" v-if="userInfo.identity">
						<text>{{ getIdentityText(userInfo.identity) }}</text>
					</view>
				</view>
			</view>
		</view>

		<view class="stats-row">
			<view class="stat-item">
				<text class="stat-num">{{ userStats.following || 0 }}</text>
				<text class="stat-label">关注</text>
			</view>
			<view class="stat-item">
				<text class="stat-num">{{ userStats.followers || 0 }}</text>
				<text class="stat-label">粉丝</text>
			</view>
			<view class="stat-item">
				<text class="stat-num">{{ userStats.posts || 0 }}</text>
				<text class="stat-label">动态</text>
			</view>
			<view class="stat-item">
				<text class="stat-num">{{ userStats.activities || 0 }}</text>
				<text class="stat-label">活动</text>
			</view>
		</view>

		<scroll-view class="content-area" scroll-y="true">
			<view class="menu-section">
				<text class="menu-title">我的服务</text>
				<view class="menu-grid">
					<view class="menu-item" @click="goToMyActivities">
						<text class="menu-icon"></text>
						<text class="menu-text">我的活动</text>
					</view>
					<view class="menu-item" @click="goToMyFavorites">
						<text class="menu-icon">❤️</text>
						<text class="menu-text">我的收藏</text>
					</view>
					<view class="menu-item" @click="goToMyOrders">
						<text class="menu-icon"></text>
						<text class="menu-text">我的订单</text>
					</view>
					<view class="menu-item" @click="goToMyBookings">
						<text class="menu-icon">📋</text>
						<text class="menu-text">我的预约</text>
					</view>
				</view>
			</view>

			<view class="menu-section">
				<text class="menu-title">设置</text>
				<view class="menu-list">
					<view class="menu-row" @click="goToProfile">
						<text class="menu-row-icon"></text>
						<text class="menu-row-text">编辑个人资料</text>
						<text class="menu-row-arrow">></text>
				</view>
				<view class="menu-row" @click="goToIdentity">
					<text class="menu-row-icon">🎭</text>
					<text class="menu-row-text">身份管理</text>
					<text class="menu-row-arrow">></text>
				</view>
				<view class="menu-row" @click="goToNotification">
					<text class="menu-row-icon"></text>
					<text class="menu-row-text">通知设置</text>
					<text class="menu-row-arrow">></text>
				</view>
				<view class="menu-row" @click="goToPrivacy">
					<text class="menu-row-icon">🔒</text>
					<text class="menu-row-text">隐私设置</text>
					<text class="menu-row-arrow">></text>
					</view>
					<view class="menu-row" @click="logout">
						<text class="menu-row-icon">🚪</text>
						<text class="menu-row-text logout">退出登录</text>
						<text class="menu-row-arrow">></text>
					</view>
				</view>
			</view>
		</scroll-view>

		<view class="bottom-nav">
			<view class="nav-item" @click="switchTab(0)">
				<text class="nav-icon">🏠</text>
				<text class="nav-text">首页</text>
			</view>
			<view class="nav-item" @click="switchTab(1)">
				<text class="nav-icon"></text>
				<text class="nav-text">乐队</text>
			</view>
			<view class="nav-item" @click="switchTab(2)">
				<text class="nav-icon"></text>
				<text class="nav-text">广场</text>
			</view>
			<view class="nav-item" @click="switchTab(3)">
				<text class="nav-icon"></text>
				<text class="nav-text">市场</text>
			</view>
			<view class="nav-item active" @click="switchTab(4)">
				<text class="nav-icon"></text>
				<text class="nav-text">我的</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import { userApi } from '../../common/utils/api.uts'
import api from '../../common/utils/api.uts'

const userInfo = ref<any>({})
const userStats = ref({
	following: 10,
	followers: 42,
	posts: 20,
	activities: 3
})

const getAvatarGradient = (): string => {
	return 'linear-gradient(135deg, #e94560, #8b1a34)'
}

const getIdentityText = (identity: string): string => {
	const texts: Record<string, string> = {
		fan: '粉丝',
		musician: '音乐人',
		band: '乐队',
		venue: '场地'
	}
	return texts[identity] || '用户'
}

const loadUserInfo = async () => {
	try {
		const res = await userApi.getProfile()
		if (res && res.code === 1000) {
			userInfo.value = res.data || {}
		}
	} catch (e) {
		console.error('Load user info error:', e)
	}
}

const loadUserStats = async () => {
	try {
		const res = await userApi.getStats()
		if (res && res.code === 1000) {
			userStats.value = res.data || {}
		}
	} catch (e) {
		console.error('Load user stats error:', e)
	}
}

const goToProfile = () => {
	uni.navigateTo({ url: '/pages/user/profile' })
}

const goToIdentity = () => {
	uni.showToast({ title: '身份管理开发中', icon: 'none' })
}

const goToNotification = () => {
	uni.showToast({ title: '通知设置开发中', icon: 'none' })
}

const goToPrivacy = () => {
	uni.showToast({ title: '隐私设置开发中', icon: 'none' })
}

const goToMyActivities = () => {
	uni.showToast({ title: '我的活动开发中', icon: 'none' })
}

const goToMyFavorites = () => {
	uni.showToast({ title: '我的收藏开发中', icon: 'none' })
}

const goToMyOrders = () => {
	uni.showToast({ title: '我的订单开发中', icon: 'none' })
}

const goToMyBookings = () => {
	uni.showToast({ title: '我的预约开发中', icon: 'none' })
}

const logout = () => {
	uni.showModal({
		title: '提示',
		content: '确定要退出登录吗？',
		success: async (res) => {
			if (res.confirm) {
				try {
					await api.logout()
				} catch (e) {
					console.error('Logout error:', e)
				}
				api.clearToken()
				uni.navigateTo({ url: '/pages/login/index' })
			}
		}
	})
}

const switchTab = (index: number) => {
	const tabs = [
		'/pages/home/index',
		'/pages/band/list',
		'/pages/square/index',
		'/pages/market/list',
		'/pages/user/index'
	]
	if (index === 4) return
	uni.switchTab({ url: tabs[index] })
}

onMounted(() => {
	const storedUserInfo = uni.getStorageSync('userInfo')
	if (storedUserInfo) {
		userInfo.value = storedUserInfo
	}
	loadUserInfo()
	loadUserStats()
})
</script>

