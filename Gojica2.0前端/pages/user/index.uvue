	background-color: #16213e;
	border-radius: 28rpx;
	overflow: hidden;
}

.menu-row {
	display: flex;
	align-items: center;
	padding: 28rpx;
	border-bottom: 1rpx solid #1a1a3e;
}

.menu-row:last-child {
	border-bottom: none;
}

.menu-row-icon {
	font-size: 36rpx;
	width: 48rpx;
}

.menu-row-text {
	flex: 1;
	font-size: 28rpx;
	color: #c0c0e0;
	margin-left: 24rpx;
}

.menu-row-text.logout {
	color: #e94560;
}

