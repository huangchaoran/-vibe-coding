	font-size: 36rpx;
	font-weight: 700;
	color: #ffffff;
	display: block;
}

.stat-label {
	font-size: 22rpx;
	color: #a0a0c0;
	display: block;
	margin-top: 6rpx;
}

.content-area {
	flex: 1;
	width: 750rpx;
	padding-bottom: 100rpx;
}

