	flex: 1;
	width: 750rpx;
	padding: 28rpx;
}

.recruit-list {
	display: flex;
	flex-direction: column;
	gap: 24rpx;
}

.recruit-card {
	background-color: #16213e;
	border-radius: 28rpx;
	padding: 28rpx;
	border: 1rpx solid #1a1a4e;
}

.recruit-header {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-bottom: 16rpx;
}

.band-avatar {
	width: 80rpx;
	height: 80rpx;
	border-radius: 20rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}

.band-emoji {
	font-size: 36rpx;
}

.recruit-title-info {
	flex: 1;
	margin-left: 20rpx;
}

.recruit-title {
	font-size: 28rpx;
	font-weight: 600;
	color: #ffffff;
	display: block;
}

.band-name {
	font-size: 22rpx;
	color: #a0a0c0;
	display: block;
	margin-top: 4rpx;
}

.recruit-tags {
	display: flex;
