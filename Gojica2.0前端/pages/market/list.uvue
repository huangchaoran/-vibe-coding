	display: flex;
	flex-direction: row;
	align-items: center;
}

.nav-icon {
	font-size: 36rpx;
	margin-left: 24rpx;
}

.search-bar {
	margin: 20rpx 28rpx;
	background-color: #1a1a3e;
	border-radius: 40rpx;
	padding: 16rpx 28rpx;
	display: flex;
	flex-direction: row;
	align-items: center;
}

.search-icon {
	font-size: 28rpx;
	margin-right: 16rpx;
}

.search-placeholder {
	font-size: 26rpx;
	color: #5a5a8a;
}

.filter-scroll {
	width: 750rpx;
	background-color: #0d0d1f;
	border-bottom: 1rpx solid #1a1a4e;
}

.filter-tags {
	display: flex;
	flex-direction: row;
	padding: 20rpx 28rpx;
	white-space: nowrap;
}

.filter-tag {
	background-color: #16213e;
	color: #a0a0c0;
	font-size: 24rpx;
	padding: 12rpx 24rpx;
	border-radius: 28rpx;
	margin-right: 16rpx;
	border: 1rpx solid #1a1a4e;
}

.filter-tag.active {
	background-color: #e94560;
	color: #ffffff;
	border-color: #e94560;
}

.content-area {
	flex: 1;
	width: 750rpx;
	padding: 28rpx;
	padding-bottom: 100rpx;
}

.product-grid {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 20rpx;
}

.product-card {
	background-color: #16213e;
	border-radius: 28rpx;
	overflow: hidden;
	border: 1rpx solid #1a1a4e;
}

.product-cover {
	width: 100%;
	height: 240rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	position: relative;
}

.product-emoji {
	font-size: 72rpx;
}

.favorite-btn {
	position: absolute;
	top: 16rpx;
	right: 16rpx;
}

.product-info {
	padding: 20rpx;
}

.product-title {
	font-size: 24rpx;
	font-weight: 600;
	color: #ffffff;
	display: block;
}

.product-price {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-top: 8rpx;
}

.price-current {
	font-size: 30rpx;
	font-weight: 700;
	color: #e94560;
}

.price-original {
	font-size: 22rpx;
	color: #5a5a8a;
	text-decoration: line-through;
	margin-left: 8rpx;
}

.product-seller {
	font-size: 22rpx;
