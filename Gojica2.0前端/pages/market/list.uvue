}

.empty-text {
	font-size: 26rpx;
	color: #5a5a8a;
	margin-top: 20rpx;
}

.bottom-nav {
	position: fixed;
	bottom: 0;
	left: 0;
	right: 0;
	height: 100rpx;
	background-color: #0f0f23;
	border-top: 1rpx solid #1a1a3e;
	display: flex;
	flex-direction: row;
	align-items: center;
}

.nav-item {
	flex: 1;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
}

.nav-icon {
	font-size: 40rpx;
	color: #5a5a8a;
}

.nav-text {
	font-size: 20rpx;
	color: #5a5a8a;
	margin-top: 4rpx;
}

.nav-item.active .nav-icon {
	color: #e94560;
}

.nav-item.active .nav-text {
	color: #e94560;
}
</style>

