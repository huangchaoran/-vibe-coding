	height: 1rpx;
	background-color: #1a1a4e;
	margin: 24rpx 0;
}

.section {
	margin-bottom: 24rpx;
}

.section-title {
	font-size: 30rpx;
	font-weight: 700;
	color: #ffffff;
	display: block;
	margin-bottom: 16rpx;
}

.section-content {
	font-size: 28rpx;
	color: #a0a0c0;
	line-height: 1.6;
}

.seller-info {
	display: flex;
	flex-direction: row;
	align-items: center;
}

.seller-avatar {
	width: 80rpx;
	height: 80rpx;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
}

.avatar-emoji {
	font-size: 32rpx;
}

.seller-detail {
	flex: 1;
	margin-left: 20rpx;
}

.seller-name {
	font-size: 28rpx;
	font-weight: 600;
	color: #ffffff;
	display: block;
}

.seller-meta {
	font-size: 22rpx;
	color: #a0a0c0;
