	margin-bottom: 16rpx;
}

.post-image {
	height: 160rpx;
	background: linear-gradient(135deg, #1a1a3e, #e94560);
	border-radius: 16rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}

.image-placeholder {
	font-size: 48rpx;
	color: rgba(255, 255, 255, 0.3);
}

.post-actions {
	display: flex;
	flex-direction: row;
	gap: 36rpx;
}

.action-item {
	display: flex;
	flex-direction: row;
	align-items: center;
	color: #5a5a8a;
