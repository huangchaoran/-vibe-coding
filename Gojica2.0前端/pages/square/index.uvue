	display: flex;
	flex-direction: column;
	gap: 24rpx;
}

.post-card {
	background-color: #16213e;
	border-radius: 28rpx;
	padding: 28rpx;
	border: 1rpx solid #1a1a4e;
}

.post-header {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-bottom: 20rpx;
}

.post-avatar {
	width: 76rpx;
	height: 76rpx;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}

