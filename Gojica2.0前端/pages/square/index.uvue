	display: flex;
	flex-direction: row;
	padding: 20rpx 28rpx;
	border-bottom: 1rpx solid #1a1a4e;
}

.filter-tab {
	flex: 1;
	text-align: center;
	padding: 12rpx 0;
	color: #5a5a8a;
	font-size: 28rpx;
	position: relative;
}

