<template>
	<view class="band-list-container">
		<view class="top-nav">
			<text class="nav-title"> 乐队</text>
			<view class="nav-right">
				<text class="nav-icon" @click="goToSearch"></text>
				<text class="nav-icon" @click="goToCreate">+</text>
			</view>
		</view>

		<scroll-view class="filter-scroll" scroll-x="true">
			<view class="filter-tags">
				<view
					class="filter-tag"
					v-for="style in styles"
					:key="style.value"
					:class="{ active: currentStyle === style.value }"
					@click="selectStyle(style.value)"
				>
					<text>{{ style.label }}</text>
				</view>
			</view>
		</scroll-view>

		<scroll-view class="content-area" scroll-y="true" @scrolltolower="loadMore">
			<view class="band-list">
				<view class="band-item" v-for="band in bands" :key="band.id" @click="goToDetail(band.id)">
					<view class="band-avatar" :style="{ background: getBandGradient(band.style) }">
						<text class="band-emoji">{{ getBandEmoji(band.style) }}</text>
					</view>
					<view class="band-info">
						<text class="band-name">{{ band.name }}</text>
						<text class="band-meta">{{ band.style }} · {{ band.member_count || 0 }}名成员</text>
					</view>
					<view class="band-tag">
						<text>{{ band.style }}</text>
					</view>
				</view>
			</view>

			<view class="loading-more" v-if="loading">
				<text>加载中..</text>
			</view>
			<view class="no-more" v-if="!loading && noMore">
				<text>没有更多了</text>
			</view>
		</scroll-view>

		<view class="bottom-nav">
			<view class="nav-item" @click="switchTab(0)">
				<text class="nav-icon">🏠</text>
				<text class="nav-text">首页</text>
			</view>
			<view class="nav-item active" @click="switchTab(1)">
				<text class="nav-icon"></text>
				<text class="nav-text">乐队</text>
			</view>
			<view class="nav-item" @click="switchTab(2)">
				<text class="nav-icon"></text>
				<text class="nav-text">广场</text>
			</view>
			<view class="nav-item" @click="switchTab(3)">
				<text class="nav-icon"></text>
				<text class="nav-text">市场</text>
			</view>
			<view class="nav-item" @click="switchTab(4)">
				<text class="nav-icon"></text>
				<text class="nav-text">我的</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import { bandApi } from '../../common/utils/api.uts'
import { MUSIC_STYLES } from '../../common/utils/theme'

const styles = ref([{ label: '全部', value: '' }, ...MUSIC_STYLES])
const currentStyle = ref('')
const bands = ref<any[]>([])
const page = ref(1)
const pageSize = 20
const loading = ref(false)
const noMore = ref(false)

const getBandGradient = (style: string): string => {
	const gradients: Record<string, string> = {
		rock: 'linear-gradient(135deg, #e94560, #8b1a34)',
		jazz: 'linear-gradient(135deg, #9b59b6, #8e44ad)',
		pop: 'linear-gradient(135deg, #3498db, #2980b9)',
		folk: 'linear-gradient(135deg, #27ae60, #2ecc71)',
		metal: 'linear-gradient(135deg, #34495e, #2c3e50)',
		blues: 'linear-gradient(135deg, #f39c12, #e67e22)'
	}
	return gradients[style?.toLowerCase()] || 'linear-gradient(135deg, #e94560, #8b1a34)'
}

const getBandEmoji = (style: string): string => {
	const emojis: Record<string, string> = {
		rock: '',
		jazz: '',
		pop: '',
		folk: '',
		metal: '',
		blues: ''
	}
	return emojis[style?.toLowerCase()] || '🎵'
}

const loadBands = async (reset = false) => {
	if (loading.value) return
	if (reset) {
		page.value = 1
		noMore.value = false
		bands.value = []
	}

	loading.value = true
	try {
		const params: any = {
			page: page.value,
			pageSize
		}
		if (currentStyle.value) {
			params.style = currentStyle.value
		}

		const res = await bandApi.getList(params)
		if (res && res.code === 1000) {
			const list = res.data?.list || []
			if (reset) {
				bands.value = list
			} else {
				bands.value = [...bands.value, ...list]
			}

			if (list.length < pageSize) {
				noMore.value = true
			} else {
				page.value++
			}
		}
	} catch (e) {
		console.error('Load bands error:', e)
		uni.showToast({ title: '加载失败', icon: 'none' })
	} finally {
		loading.value = false
	}
}

const selectStyle = (style: string) => {
	currentStyle.value = style
	loadBands(true)
}

const loadMore = () => {
	if (!noMore.value) {
		loadBands(false)
	}
}

const goToDetail = (id: number) => {
	uni.navigateTo({ url: `/pages/band/detail?id=${id}` })
}

const goToSearch = () => {
	uni.navigateTo({ url: '/pages/search/index' })
}

const goToCreate = () => {
	uni.navigateTo({ url: '/pages/band/create' })
}

const switchTab = (index: number) => {
	const tabs = [
		'/pages/home/index',
		'/pages/band/list',
		'/pages/square/index',
		'/pages/market/list',
		'/pages/user/index'
	]
	if (index === 1) return
	uni.switchTab({ url: tabs[index] })
}

onMounted(() => {
	loadBands(true)
})
</script>

<style>
