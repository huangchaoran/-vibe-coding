<template>
	<view class="band-detail-container">
		<view class="detail-cover" :style="{ background: getBandGradient(band.style) }">
			<text class="cover-emoji">{{ getBandEmoji(band.style) }}</text>
			<view class="back-btn" @click="goBack">
				<text>></text>
			</view>
		</view>

		<scroll-view class="content-area" scroll-y="true">
			<view class="detail-content">
				<view class="band-info">
					<text class="band-name">{{ band.name }}</text>
					<view class="band-tags">
						<view class="tag">
							<text>{{ band.style }}</text>
						</view>
						<view class="tag">
							<text>{{ band.member_count || 0 }}人</text>
						</view>
						<view class="tag" v-if="band.created_at">
							<text>成立{{ getYear(band.created_at) }}</text>
						</view>
					</view>
					<text class="band-intro" v-if="band.intro">{{ band.intro }}</text>
				</view>

				<view class="section" v-if="members.length > 0">
					<view class="section-header">
						<text class="section-title">乐队成员</text>
					</view>
					<view class="members-grid">
						<view class="member-item" v-for="member in members" :key="member.id">
							<view class="member-avatar" :style="{ background: getMemberGradient(member.role) }">
								<text class="member-emoji">{{ getRoleEmoji(member.role) }}</text>
							</view>
							<text class="member-name">{{ member.user?.nickname || '未知' }}</text>
							<text class="member-role">{{ member.instrument || member.role }}</text>
						</view>
					</view>
				</view>

				<view class="section" v-if="activities.length > 0">
					<view class="section-header">
						<text class="section-title">参与活动</text>
					</view>
					<view class="activities-list">
						<view class="activity-item" v-for="activity in activities" :key="activity.id" @click="goToActivity(activity.id)">
							<view class="activity-cover" :style="{ background: getActivityGradient(activity.type) }">
								<text class="activity-emoji">{{ getActivityEmoji(activity.type) }}</text>
							</view>
							<view class="activity-info">
								<text class="activity-title">{{ activity.title }}</text>
								<view class="activity-meta">
									<text>📅 {{ formatDate(activity.start_time) }}</text>
									<text>{{ activity.location }}</text>
								</view>
							</view>
						</view>
					</view>
				</view>
			</view>
		</scroll-view>

		<view class="bottom-action">
			<view class="action-btn secondary" @click="sendMessage">
				<text>💌 私信</text>
			</view>
			<view class="action-btn primary" @click="toggleFollow">
				<text>{{ isFollowed ? '❤️ 已关注' : '🤍 关注' }}</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import { bandApi, userApi } from '../../common/utils/api.uts'

const bandId = ref<number>(0)
const band = ref<any>({})
const members = ref<any[]>([])
const activities = ref<any[]>([])
const isFollowed = ref(false)

const getBandGradient = (style: string): string => {
	const gradients: Record<string, string> = {
		rock: 'linear-gradient(135deg, #e94560, #16213e)',
		jazz: 'linear-gradient(135deg, #9b59b6, #16213e)',
		pop: 'linear-gradient(135deg, #3498db, #16213e)',
		folk: 'linear-gradient(135deg, #27ae60, #16213e)',
		metal: 'linear-gradient(135deg, #34495e, #16213e)',
		blues: 'linear-gradient(135deg, #f39c12, #16213e)'
	}
	return gradients[style?.toLowerCase()] || 'linear-gradient(135deg, #e94560, #16213e)'
}

const getBandEmoji = (style: string): string => {
	const emojis: Record<string, string> = {
		rock: '🎸',
		jazz: '🎷',
		pop: '🎤',
		folk: '🎻',
		metal: '🤘',
		blues: '🎺'
	}
	return emojis[style?.toLowerCase()] || '🎵'
}

const getMemberGradient = (role: string): string => {
	const gradients: Record<string, string> = {
		vocal: 'linear-gradient(135deg, #e94560, #8b1a34)',
		guitar: 'linear-gradient(135deg, #9b59b6, #8e44ad)',
		keyboard: 'linear-gradient(135deg, #3498db, #2980b9)',
		drum: 'linear-gradient(135deg, #27ae60, #2ecc71)'
	}
	return gradients[role?.toLowerCase()] || 'linear-gradient(135deg, #e94560, #8b1a34)'
}

const getRoleEmoji = (role: string): string => {
	const emojis: Record<string, string> = {
		vocal: '🎤',
		guitar: '🎸',
		keyboard: '🎹',
		drum: '🥁',
		bass: '🎸'
	}
	return emojis[role?.toLowerCase()] || '🎵'
}

const getActivityGradient = (type: string): string => {
	const gradients: Record<string, string> = {
		performance: 'linear-gradient(135deg, #e94560, #8b1a34)',
		competition: 'linear-gradient(135deg, #f39c12, #e67e22)',
		rehearsal: 'linear-gradient(135deg, #3498db, #2980b9)',
		course: 'linear-gradient(135deg, #9b59b6, #8e44ad)'
	}
	return gradients[type?.toLowerCase()] || 'linear-gradient(135deg, #16213e, #0f4a8a)'
}

const getActivityEmoji = (type: string): string => {
	const emojis: Record<string, string> = {
		performance: '🎤',
		competition: '🏆',
		rehearsal: '🎹',
		course: '📚'
	}
	return emojis[type?.toLowerCase()] || '🎵'
}

const getYear = (dateStr: string): string => {
	if (!dateStr) return ''
	const date = new Date(dateStr)
	return date.getFullYear().toString()
}

const formatDate = (dateStr: string): string => {
	if (!dateStr) return '待定'
	const date = new Date(dateStr)
	const month = date.getMonth() + 1
	const day = date.getDate()
	return month + '月' + day + '日'
}

const loadBandDetail = async () => {
	try {
		uni.showLoading({ title: '加载中..' })

		const [detailRes, membersRes, activitiesRes] = await Promise.all([
			bandApi.getDetail(bandId.value),
			bandApi.getMembers(bandId.value),
			bandApi.getActivities(bandId.value)
		])

		if (detailRes && detailRes.code === 1000) {
			band.value = detailRes.data || {}
		}

		if (membersRes && membersRes.code === 1000) {
			members.value = membersRes.data || []
		}

		if (activitiesRes && activitiesRes.code === 1000) {
			activities.value = Array.isArray(activitiesRes.data) ? activitiesRes.data : activitiesRes.data?.list || []
		}

		checkFollowStatus()
		uni.hideLoading()
	} catch (e) {
		uni.hideLoading()
		console.error('Load band detail error:', e)
		uni.showToast({ title: '加载失败', icon: 'none' })
	}
}

const checkFollowStatus = async () => {
	try {
		isFollowed.value = false // 先重置
		const res = await userApi.getFollows()
		if (res && res.code === 1000 && res.data) {
			const follows = res.data.list || res.data || []
			// Bug修复: f.id是关注记录ID，应该检查 f.band?.id 才是乐队ID
			const isFollowing = follows.some((f: any) => f.band?.id === bandId.value)
			if (isFollowing) {
				isFollowed.value = true
			}
		}
	} catch (e) {
		console.log('Check follow status error:', e)
	}
}

const toggleFollow = async () => {
	try {
		if (isFollowed.value) {
			// 已关注 -> 取消关注
			const unfollowRes = await bandApi.unfollow(bandId.value)
			if (unfollowRes && (unfollowRes.code === 1000 || unfollowRes.code === 1001)) {
				isFollowed.value = false
				uni.showToast({ title: '已取消关注', icon: 'success' })
			} else {
				uni.showToast({ title: '操作失败', icon: 'none' })
			}
		} else {
			// 未关注 -> 添加关注
			const followRes = await bandApi.follow(bandId.value)
			if (followRes && (followRes.code === 1000 || followRes.code === 1001)) {
				isFollowed.value = true
				uni.showToast({ title: '关注成功', icon: 'success' })
			} else {
				uni.showToast({ title: '操作失败', icon: 'none' })
			}
		}
	} catch (e) {
		console.error('Toggle follow error:', e)
		uni.showToast({ title: '操作失败', icon: 'none' })
	}
}

const sendMessage = () => {
	uni.showToast({ title: '私信功能开发中', icon: 'none' })
}

const goToActivity = (id: number) => {
	uni.navigateTo({ url: '/pages/activity/detail?id=' + id })
}

const goBack = () => {
	uni.navigateBack()
}

onMounted(() => {
	const pages = getCurrentPages()
	if (pages.length > 0) {
		const currentPage = pages[pages.length - 1] as any
		if (currentPage.options && currentPage.options.id) {
			bandId.value = parseInt(currentPage.options.id)
		}
	}

	if (bandId.value) {
		loadBandDetail()
		checkFollowStatus()
	} else {
		uni.showToast({ title: '参数错误', icon: 'none' })
		uni.navigateBack()
	}
})
</script>

<style>
