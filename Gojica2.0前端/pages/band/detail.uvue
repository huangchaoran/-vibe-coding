	position: absolute;
	top: 24rpx;
	left: 28rpx;
	width: 64rpx;
	height: 64rpx;
	background-color: rgba(0, 0, 0, 0.4);
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
}

.back-btn text {
	font-size: 32rpx;
	color: #ffffff;
}

