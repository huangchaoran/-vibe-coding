	font-size: 28rpx;
	color: #a0a0c0;
	line-height: 1.6;
	margin-top: 16rpx;
	display: block;
}

.section {
	margin-bottom: 32rpx;
}

.section-header {
	margin-bottom: 20rpx;
}

.section-title {
	font-size: 30rpx;
	font-weight: 700;
	color: #ffffff;
}

.members-grid {
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	gap: 28rpx;
}

.member-item {
	display: flex;
	flex-direction: column;
	align-items: center;
}

.member-avatar {
	width: 80rpx;
	height: 80rpx;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
}

.member-emoji {
	font-size: 32rpx;
}

.member-name {
	font-size: 20rpx;
	color: #a0a0c0;
	margin-top: 10rpx;
}

.member-role {
	font-size: 18rpx;
	color: #e94560;
	margin-top: 4rpx;
}

.activities-list {
	display: flex;
	flex-direction: column;
	gap: 24rpx;
}

.activity-item {
	display: flex;
	flex-direction: row;
	background-color: #16213e;
	border-radius: 24rpx;
	overflow: hidden;
	border: 1rpx solid #1a1a4e;
}

.activity-cover {
	width: 120rpx;
	height: 120rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}

.activity-emoji {
	font-size: 40rpx;
}

.activity-info {
	flex: 1;
	padding: 20rpx;
}

.activity-title {
	font-size: 28rpx;
	font-weight: 600;
	color: #ffffff;
	display: block;
}

.activity-meta {
	display: flex;
	flex-direction: row;
	margin-top: 10rpx;
}

.activity-meta text {
	font-size: 22rpx;
	color: #a0a0c0;
	margin-right: 20rpx;
}

.bottom-action {
	position: fixed;
	bottom: 0;
	left: 0;
	right: 0;
	padding: 24rpx 28rpx;
	background-color: #0f0f23;
	border-top: 1rpx solid #1a1a3e;
	display: flex;
	flex-direction: row;
	gap: 20rpx;
}

.action-btn {
	flex: 1;
	border-radius: 40rpx;
	padding: 24rpx;
	text-align: center;
}

.action-btn text {
	font-size: 28rpx;
	font-weight: 600;
}

.action-btn.secondary {
	background-color: #16213e;
	border: 1rpx solid #e94560;
}

.action-btn.secondary text {
	color: #e94560;
}

.action-btn.primary {
	background-color: #e94560;
}

.action-btn.primary text {
	color: #ffffff;
}
</style>