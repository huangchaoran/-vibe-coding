	font-size: 28rpx;
	font-weight: 600;
	color: #ffffff;
	display: block;
}

.room-meta {
	display: flex;
	flex-direction: row;
	margin-top: 12rpx;
}

.meta-item {
	font-size: 22rpx;
	color: #a0a0c0;
	margin-right: 24rpx;
}

.room-footer {
	display: flex;
	flex-direction: row;
	justify-content: space-between;
	align-items: center;
	margin-top: 16rpx;
}

.room-price {
	display: flex;
	flex-direction: row;
	align-items: baseline;
}

.price {
	font-size: 32rpx;
	font-weight: 700;
	color: #e94560;
}

.price-unit {
	font-size: 22rpx;
	color: #a0a0c0;
	margin-left: 4rpx;
}

.book-btn {
	background-color: #e94560;
	border-radius: 28rpx;
	padding: 12rpx 32rpx;
}

.book-btn text {
	font-size: 24rpx;
