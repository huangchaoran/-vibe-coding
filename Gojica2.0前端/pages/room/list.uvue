	display: flex;
	flex-direction: row;
	padding: 20rpx 28rpx;
	white-space: nowrap;
}

.filter-tag {
	background-color: #16213e;
	color: #a0a0c0;
	font-size: 24rpx;
	padding: 12rpx 24rpx;
	border-radius: 28rpx;
	margin-right: 16rpx;
	border: 1rpx solid #1a1a4e;
}

.filter-tag.active {
	background-color: #e94560;
	color: #ffffff;
	border-color: #e94560;
}

.content-area {
	flex: 1;
	width: 750rpx;
	padding: 28rpx;
}

.room-list {
	display: flex;
	flex-direction: column;
	gap: 24rpx;
}

.room-card {
	background-color: #16213e;
	border-radius: 28rpx;
	overflow: hidden;
	border: 1rpx solid #1a1a4e;
}

.room-cover {
	width: 100%;
	height: 220rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	position: relative;
}

.room-emoji {
	font-size: 64rpx;
}

.available-badge {
	position: absolute;
	top: 20rpx;
	right: 20rpx;
	background-color: #27ae60;
	padding: 8rpx 16rpx;
	border-radius: 16rpx;
}

.available-badge text {
	font-size: 20rpx;
	color: #ffffff;
}

