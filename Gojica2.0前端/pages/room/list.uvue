<template>
	<view class="room-list-container">
		<view class="top-nav">
			<text class="nav-title">🏠 排练室</text>
			<view class="nav-right">
				<text class="nav-icon" @click="goToSearch"></text>
			</view>
		</view>

		<scroll-view class="filter-scroll" scroll-x="true">
			<view class="filter-tags">
				<view
					class="filter-tag"
					v-for="city in cities"
					:key="city.value"
					:class="{ active: currentCity === city.value }"
					@click="selectCity(city.value)"
				>
					<text>{{ city.label }}</text>
				</view>
			</view>
		</scroll-view>

		<scroll-view class="content-area" scroll-y="true">
			<view class="room-list">
				<view class="room-card" v-for="room in rooms" :key="room.id" @click="goToDetail(room.id)">
					<view class="room-cover" :style="{ background: getRoomGradient() }">
						<text class="room-emoji"></text>
						<view class="available-badge" v-if="room.isAvailable">
							<text>可预约</text>
						</view>
					</view>
					<view class="room-body">
						<text class="room-name">{{ room.name }}</text>
						<view class="room-meta">
							<text class="meta-item"> {{ room.location }}</text>
							<text class="meta-item">👥 {{ room.capacity }}人</text>
						</view>
						<view class="room-footer">
							<view class="room-price">
								<text class="price">¥{{ room.price_per_hour }}</text>
								<text class="price-unit">/小时</text>
							</view>
							<view class="book-btn" @click.stop="bookRoom(room.id)">
								<text>立即预约</text>
							</view>
						</view>
					</view>
				</view>
			</view>

			<view class="empty-state" v-if="rooms.length === 0">
				<text class="empty-icon">🏠</text>
				<text class="empty-text">暂无排练室</text>
			</view>
		</scroll-view>
	</view>
</template>

<script setup lang="uts">
import { ref, onMounted } from 'vue'
import { roomApi } from '../../common/utils/api.uts'

const cities = ref([
	{ label: '全部', value: '' },
	{ label: '北京', value: 'beijing' },
	{ label: '上海', value: 'shanghai' },
	{ label: '成都', value: 'chengdu' }
])
const currentCity = ref('')
const rooms = ref<any[]>([])

const getRoomGradient = (): string => {
	return 'linear-gradient(135deg, #16213e, #0f4a8a)'
}

const loadRooms = async () => {
	try {
		const params: any = {}
		if (currentCity.value) {
			params.city = currentCity.value
		}

		const res = await roomApi.getList(params)
		if (res && res.code === 1000) {
			rooms.value = res.data?.list || []
		}
	} catch (e) {
		console.error('Load rooms error:', e)
		uni.showToast({ title: '加载失败', icon: 'none' })
	}
}

const selectCity = (city: string) => {
	currentCity.value = city
	loadRooms()
}

const goToDetail = (id: number) => {
	uni.showToast({ title: '排练室详情开发中', icon: 'none' })
}

const goToSearch = () => {
	uni.navigateTo({ url: '/pages/search/index' })
}

const bookRoom = (id: number) => {
	uni.showToast({ title: '预约功能开发中', icon: 'none' })
}

onMounted(() => {
	loadRooms()
})
</script>

<style>
