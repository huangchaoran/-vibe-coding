	font-size: 100rpx;
}

.back-btn {
	position: absolute;
	top: 24rpx;
	left: 28rpx;
	width: 64rpx;
	height: 64rpx;
	background-color: rgba(0, 0, 0, 0.4);
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
}

.back-btn text {
	font-size: 32rpx;
	color: #ffffff;
}

.status-badge {
	position: absolute;
	top: 24rpx;
	right: 28rpx;
	padding: 12rpx 24rpx;
	border-radius: 24rpx;
}

.status-badge text {
	font-size: 24rpx;
	color: #ffffff;
}

.content-area {
	flex: 1;
	width: 750rpx;
	padding-bottom: 120rpx;
}

.detail-content {
	padding: 32rpx 28rpx;
}

.activity-info {
	margin-bottom: 24rpx;
}

.activity-title {
	font-size: 40rpx;
	font-weight: 700;
	color: #ffffff;
	display: block;
}

.activity-tags {
	display: flex;
	flex-direction: row;
	margin-top: 16rpx;
}

.tag {
	background-color: rgba(233, 69, 96, 0.15);
	color: #e94560;
	font-size: 22rpx;
	padding: 8rpx 20rpx;
	border-radius: 20rpx;
	margin-right: 16rpx;
}

.divider {
	height: 1rpx;
	background-color: #1a1a4e;
	margin: 24rpx 0;
}

.detail-rows {
	display: flex;
	flex-direction: column;
}

.detail-row {
	display: flex;
	flex-direction: row;
	align-items: center;
	margin-bottom: 20rpx;
}

.row-icon {
	font-size: 28rpx;
	margin-right: 16rpx;
}

.row-content {
	flex: 1;
	display: flex;
	flex-direction: column;
}

.row-label {
	font-size: 22rpx;
	color: #5a5a8a;
}

.row-value {
	font-size: 28rpx;
	color: #ffffff;
	margin-top: 4rpx;
}

.section {
	margin-bottom: 24rpx;
}

.section-title {
	font-size: 30rpx;
	font-weight: 700;
	color: #ffffff;
	display: block;
	margin-bottom: 16rpx;
}

.section-content {
	font-size: 28rpx;
	color: #a0a0c0;
	line-height: 1.6;
}

.bands-grid {
	display: flex;
	flex-direction: row;
	flex-wrap: wrap;
	gap: 24rpx;
}

.band-item {
	display: flex;
	flex-direction: column;
	align-items: center;
}

.band-avatar {
	width: 80rpx;
	height: 80rpx;
	border-radius: 20rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}

.band-emoji {
	font-size: 32rpx;
}

.band-name {
	font-size: 22rpx;
	color: #a0a0c0;
	margin-top: 8rpx;
}

.bottom-action {
	position: fixed;
	bottom: 0;
	left: 0;
	right: 0;
	padding: 24rpx 28rpx;
	background-color: #0f0f23;
	border-top: 1rpx solid #1a1a3e;
	display: flex;
	flex-direction: row;
	gap: 20rpx;
}

.action-btn {
	flex: 1;
	border-radius: 40rpx;
	padding: 24rpx;
	text-align: center;
}

.action-btn text {
	font-size: 28rpx;
	font-weight: 600;
}

.action-btn.secondary {
	background-color: #16213e;
	border: 1rpx solid #e94560;
}

.action-btn.secondary text {
	color: #e94560;
}

.action-btn.primary {
	background-color: #e94560;
}

.action-btn.primary text {
	color: #ffffff;
}

.action-btn.disabled {
	background-color: #333333;
}

.action-btn.disabled text {
	color: #666666;
}
</style>